<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supermarket.mapper.MemberMapper">

    <resultMap id="BaseResultMap" type="com.supermarket.entity.Member">
        <id column="member_id" property="memberId"/>
        <result column="account_no" property="accountNo"/>
        <result column="nickname" property="nickname"/>
        <result column="points" property="points"/>
        <result column="phone" property="phone"/>
        <result column="create_time" property="createTime"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectByAccountNo" resultMap="BaseResultMap">
        SELECT * FROM member WHERE account_no = #{accountNo} AND status = 1
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM member WHERE member_id = #{memberId}
    </select>

    <update id="addPoints">
        UPDATE member SET points = points + #{points} WHERE member_id = #{memberId}
    </update>

    <update id="deductPoints">
        UPDATE member SET points = points - #{points} WHERE member_id = #{memberId} AND points >= #{points}
    </update>

    <insert id="insert" useGeneratedKeys="true" keyProperty="memberId" parameterType="com.supermarket.entity.Member">
        INSERT INTO member(account_no, nickname, points, phone)
        VALUES(#{accountNo}, #{nickname}, #{points}, #{phone})
    </insert>

</mapper>
